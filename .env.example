# Copier vers .env.local à cet endroit (racine effinor-platform/).
# Toutes les apps chargent ce dossier : ERP (Next), website / landings (Vite).

# --- Supabase (obligatoire pour l’ERP et les apps qui s’y connectent) ---
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Même couple pour les apps Vite du monorepo (ou laisse vide si tu n’utilises que l’ERP)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optionnel (serveur uniquement, ne jamais exposer au navigateur)
# SUPABASE_SERVICE_ROLE_KEY=

# --- URLs de l’ERP (liens emails, redirections) ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_URL=http://localhost:3001

# --- IA / autre (optionnel) ---
# OPENAI_API_KEY=
# Recherche GPT (quantification) — Responses API + recherche web
# OPENAI_LEAD_GEN_GPT_RESEARCH_MODEL=gpt-4.1
# OPENAI_LEAD_GEN_GPT_RESEARCH_TIMEOUT_MS=120000
# OPENAI_LEAD_GEN_GPT_RESEARCH_MAX_OUTPUT_TOKENS=8192
# Données légales France (recherche entreprise / SIREN)
# PAPPERS_API_KEY=
# PAPPERS_API_BASE_URL=https://api.pappers.fr/v2
# PAPPERS_API_TIMEOUT_MS=20000
# IMPERSONATION_COOKIE_SECRET=

# --- Lead generation · Apify (serveur uniquement, import Google Maps contrôlé) ---
# Peuvent aussi être définis dans apps/erp/.env.local (Next charge racine + apps/erp).
# Jeton API : https://console.apify.com/account/integrations
# APIFY_API_TOKEN=
# Identifiant de l’actor (ex. compass~crawler-google-places ou user~nom-actor)
# APIFY_GOOGLE_MAPS_ACTOR_ID=
#
# Étape 11 — vérification site (Firecrawl, serveur uniquement) :
# FIRECRAWL_API_KEY=

# --- E-mail (SMTP Hostinger / générique) — voir apps/erp/lib/email/gmail-transport.ts ---
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_PASS=
# SMTP_REPLY_TO=
# MAIL_FROM=
# MAIL_FROM_NAME=

# --- E-mail de prospection après qualification quantificateur (lead generation) ---
# QUALIFIED_LEAD_PROSPECT_EMAIL_ENABLED=true
# OPENAI_QUALIFIED_LEAD_EMAIL_MODEL=gpt-4.1-mini
# OPENAI_QUALIFIED_LEAD_EMAIL_TIMEOUT_MS=60000
# QUALIFIED_LEAD_EMAIL_FROM=
# QUALIFIED_LEAD_EMAIL_FROM_NAME=
# Logos HTML (URLs HTTPS publiques — pas de base64 énorme)
# EMAIL_TOTALENERGIES_LOGO_URL=https://
# EMAIL_EFFINOR_LOGO_URL=