# Copier vers .env.local et renseigner les valeurs du projet Supabase.
# Tableau : Settings → API
#
# Les comptes de test (seed.sql) doivent exister dans CE projet : même URL que ci-dessous.
# Si .env pointe vers le cloud alors que vous avez seedé en local (ou l’inverse), la connexion échoue.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Déploiement Docker sans build args : mêmes valeurs qu’au-dessus, lues au runtime (layout + /api/public/supabase-config).
# PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Alias reconnus côté serveur : SUPABASE_URL, SUPABASE_ANON_KEY (comme sur le tableau Supabase → API).

# Docker / prod : openssl rand -base64 32 — même valeur au build et au runtime (évite « Server Action not found »).
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Clé service_role (Settings → API) — uniquement côté serveur, jamais exposée au navigateur.
# Requise pour la création d’utilisateurs par le super administrateur (Réglages).
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Impersonation (super_admin) : cookie httpOnly signé — min. 32 caractères. Ex. openssl rand -hex 32
# IMPERSONATION_COOKIE_SECRET=

# Storage : nom exact du bucket pour les fichiers médias des leads (photos, cadastre, audio).
# Par défaut dans le code : Lads_fichiers
# NEXT_PUBLIC_SUPABASE_LEAD_MEDIA_BUCKET=Lads_fichiers

# Notes depuis l’audio (transcription Whisper + synthèse GPT) — uniquement côté serveur
# OPENAI_API_KEY=sk-...
# Modèle pour la synthèse des notes (optionnel) :
# OPENAI_CHAT_MODEL=gpt-4o-mini
# alias supporté : OPENAI_MODEL

# --- E-mail : soit Gmail, soit SMTP (Hostinger, etc.) ---
#
# Option A — Gmail (mot de passe d’application : Google > Sécurité > Mots de passe d’application)
GMAIL_USER=votre-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_FROM_NAME=Effinor
#
# Option B — SMTP générique (prioritaire si défini) : ex. Hostinger
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=no-reply@effinor.app
# SMTP_PASSWORD=mot_de_passe_de_la_boîte
# MAIL_FROM=no-reply@effinor.app
# MAIL_FROM_NAME=Effinor
# (alias mot de passe : SMTP_PASS)
#
# E-mail « création d’utilisateur » (Réglages) via Hostinger no-reply sans changer le reste des envois :
# USER_CREATION_SMTP_HOST=smtp.hostinger.com
# USER_CREATION_SMTP_PORT=465
# USER_CREATION_SMTP_USER=no-reply@effinor.app
# USER_CREATION_SMTP_PASSWORD=mot_de_passe_de_la_boîte
# USER_CREATION_MAIL_FROM=no-reply@effinor.app
# USER_CREATION_MAIL_FROM_NAME=Effinor
# Si vous authentifiez SMTP avec contact@… mais voulez l’expéditeur no-reply@… : renseignez USER_CREATION_MAIL_FROM
# (ou MAIL_FROM global) — sinon l’ancienne logique utilisait le login SMTP comme From.
# Port 587 + STARTTLS (souvent plus fiable si 465 renvoie 535) :
# USER_CREATION_SMTP_PORT=587
# USER_CREATION_SMTP_SECURE=false
#
# Gmail seul + expéditeur différent de GMAIL_USER : l’envoi est refusé avec un message explicite
# (sauf si alias Google validé : EFFINOR_ALLOW_GMAIL_SEND_AS_FOR_USER_CREATION=true).

# --- Slack (notifications ERP, backend uniquement) ---
# SLACK_ENABLED=false
# URL publique de l’app pour les liens « Ouvrir » dans les messages (optionnel)
# URL publique HTTPS (emails : pixel d’ouverture, liens). À renseigner en prod (Dokploy).
# APP_URL=https://erp.example.com
# SLACK_DEFAULT_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_COMMERCIAL_WEBHOOK_URL=
# SLACK_ADMIN_WEBHOOK_URL=
# SLACK_TECHNIQUE_WEBHOOK_URL=
# SLACK_FINANCE_WEBHOOK_URL=
# SLACK_DIRECTION_WEBHOOK_URL=
# SLACK_ALERTS_WEBHOOK_URL=
# SLACK_CLOSER_WEBHOOK_URL=
# SLACK_CONFIRIMATEUR_WEBHOOK_URL=
# Rappels commerciaux : notifications Slack (due today / overdue), désactivé par défaut
# COMMERCIAL_CALLBACK_SLACK_ENABLED=false
# Phase 2 — Web API (chat.postMessage, blocks avancés)
# SLACK_BOT_TOKEN=
# SLACK_DEFAULT_CHANNEL=

# --- Automatisation métier (Slack intelligent, assignation, relances IA) ---
# AUTOMATION_SLACK_SMART_ENABLED=false
# AUTOMATION_SLACK_DEDUPE_WINDOW_MS=14400000
# AUTOMATION_SLACK_MIN_IMPACT_EUR=5000
# AUTOMATION_AUTO_ASSIGN_CONFIRMATEUR=true
# AUTOMATION_AUTO_ASSIGN_CLOSER=true
# AUTOMATION_AI_FOLLOWUP_DRAFT_ONLY=true
# AUTOMATION_AI_FOLLOWUP_AUTO_SEND=false
# AUTOMATION_AGREEMENT_STALE_DAYS_FOLLOWUP=7
#
# E-mail « premier contact » à la création d’un rappel (si e-mail + relance auto activée).
# L’app ajoute ?source=callback_email sur l’URL finale (fusion avec d’autres paramètres éventuels).
# CALLBACK_INITIAL_EMAIL_SIMULATOR_URL=https://destratificateurs.groupe-effinor.fr/
#
# Relances e-mail automatiques (rappels commerciaux) — désactivé par défaut (activer explicitement en prod).
# COMMERCIAL_CALLBACK_AUTO_FOLLOWUP_ENABLED=true
# Force l’envoi à être ignoré (tests / préprod) tout en exécutant le moteur :
# COMMERCIAL_CALLBACK_AUTO_FOLLOWUP_SKIP_SEND=false
#
# Cron HTTP : GET ou POST /api/cron/automation — priorité AUTOMATION_CRON_SECRET puis CRON_SECRET
# AUTOMATION_CRON_SECRET=...   # recommandé (openssl rand -hex 32)
# CRON_SECRET=...              # fallback si AUTOMATION_CRON_SECRET absent
#
# Orchestrateur IA cockpit (exécution auto encadrée — désactivé par défaut).
# AI_AUTONOMOUS_MODE=false
# Profil Supabase (UUID) pour tracer les actions IA dans ai_action_logs (doit exister dans public.profiles).
# AI_ORCHESTRATOR_ACTOR_USER_ID=
# Direction : UUIDs séparés par des virgules — notifications in-app + résumé horaire.
# AI_ORCHESTRATION_NOTIFY_USER_IDS=

# --- Agent opérations (inbox /agent-operations, tick via /api/cron/automation) ---
# AI_OPS_AGENT_ENABLED=false
# Actions destructives auto côté agent (V1 : surtout propositions ; aligné sur la spec).
# AI_OPS_AGENT_AUTONOMOUS_MODE=false
# Webhooks Slack agent : si absent, hérite du comportement « activé » (voir ai-ops-env).
# AI_OPS_AGENT_SLACK_ENABLED=true
# Escalade Slack canal direction (SLACK_DIRECTION_WEBHOOK_URL / routing existant).
# AI_OPS_AGENT_DIRECTION_ESCALATION_ENABLED=true
# Plafond messages agent créés par tick cron (anti-spam, max 200 côté code).
# AI_OPS_AGENT_MAX_MESSAGES_PER_TICK=40
# Conversations actives max par utilisateur (open / awaiting_user / escalated / snoozed).
# AI_OPS_MAX_OPEN_CONVERSATIONS_PER_USER=25
# Messages IA max par utilisateur et par issue_type sur une journée UTC.
# AI_OPS_MAX_AI_MSG_PER_USER_DAY_TYPE=8

# --- SLA internes (moteur cron + instances DB, avant l’agent opérations) ---
# AI_INTERNAL_SLA_ENABLED=false
# V1 : réassignation auto désactivée sauf cas sûrs — laisser false en prod.
# AI_INTERNAL_SLA_AUTONOMOUS_MODE=false
# Webhook Slack « manager » (hérite souvent de SLACK_ALERTS_WEBHOOK_URL) — true par défaut si absent.
# AI_INTERNAL_SLA_MANAGER_ALERTS=true
# Escalade Slack direction sur politique escalate_direction — true par défaut si absent.
# AI_INTERNAL_SLA_DIRECTION_ALERTS=true
