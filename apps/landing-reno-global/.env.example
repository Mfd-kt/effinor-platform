# Variables d'environnement attendues par apps/landing-reno-global
# Ces variables sont chargées via le symlink .env.local -> ../../.env.local

# Supabase (partagé avec apps/erp, apps/website, apps/landing-pac)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role Supabase — serveur uniquement (API route POST /api/simulator).
# Utilisée pour INSERT dans la table `leads` (source = 'landing_reno_global')
# depuis le simulateur public : la RLS `leads_all_active` interdit l'INSERT anon.
# ⚠️ Ne JAMAIS exposer au navigateur (pas de préfixe NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# URL publique de la landing (metadataBase, OG, canonical)
NEXT_PUBLIC_SITE_URL=https://renovation.effinor.fr
