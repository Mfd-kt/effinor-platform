# Variables d'environnement attendues par apps/website
# Ces variables sont chargées via le symlink .env.local -> ../../.env.local

# Supabase (partagé avec apps/erp)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role Supabase — serveur uniquement (API route POST /api/simulator).
# Utilisée pour INSERT dans la table `leads` depuis le simulateur public
# (RLS `leads_all_active` interdit l'INSERT anon).
# ⚠️ Ne JAMAIS exposer au navigateur (pas de préfixe NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# URL publique du site (pour metadataBase, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://effinor.fr
