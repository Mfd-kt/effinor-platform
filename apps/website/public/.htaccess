# SPA routing (React Router / Vite)
# Some hosts disable mod_rewrite or have MultiViews enabled; we add safe fallbacks.

# Prevent Apache content-negotiation from interfering with routes like /login
Options -MultiViews

# Fallback: if the host ignores mod_rewrite, serve index.html for 404s
ErrorDocument 404 /index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for an existing file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, route everything else to the SPA entry
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Avoid disclosing hosting/vendor details
  Header unset X-Powered-By

  # Cache everything on CDN by default
  Header set Cache-Control "public, s-maxage=604800, max-age=0"
  
  # Cache in browser all assets
  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header set Cache-Control "public, max-age=604800"
  </If>

  # Basic security headers (safe defaults)
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
