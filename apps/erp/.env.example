# Variables chargées depuis apps/erp/.env* puis effinor-platform/.env* (la racine **gagne** en cas de doublon).
# Mettre surtout Supabase / secrets dans effinor-platform/.env.local ; ici seulement des compléments (ex. Apify).

# =============================================================================
# Apify — Scraping multi-sources pour lead generation
# =============================================================================
# Token API Apify (récupérable depuis https://console.apify.com/account/integrations)
APIFY_TOKEN=

# =============================================================================
# Le Bon Coin — Credentials pour extraction des téléphones
# =============================================================================
# Compte LBC dédié au scraping (JAMAIS un compte personnel)
LBC_SCRAPING_EMAIL=
LBC_SCRAPING_PASSWORD=

# =============================================================================
# Cron (Dokploy Scheduled Tasks)
# =============================================================================
# Secret partagé avec les Schedules Dokploy pour sécuriser les endpoints /api/cron/*
# Header attendu : Authorization: Bearer ${AUTOMATION_CRON_SECRET}
# Génération : openssl rand -hex 32
# Fallback historique : CRON_SECRET (lu si AUTOMATION_CRON_SECRET absent).
AUTOMATION_CRON_SECRET=

# =============================================================================
# Google Maps — autocomplétion d’adresses (simulateur CEE)
# =============================================================================
# Places API + Maps JavaScript API ; restreindre par domaine en production.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# EFFINOR — Identité email (templates HTML / enveloppe transport)
# =============================================================================
EFFINOR_FROM_EMAIL=contact@effinor.fr
EFFINOR_FROM_NAME=EFFINOR
EFFINOR_SITE_URL=https://www.effinor.fr
EFFINOR_PHONE=09 78 45 50 63
EFFINOR_PHONE_DISPLAY_HOURS=Lun-Ven · 8h-18h
EFFINOR_ADDRESS=1 Avenue de l'Europe, 94320 Thiais
EFFINOR_SIRET=90754766500022
EFFINOR_LEGAL_NAME=EFFINOR LIGHTING
