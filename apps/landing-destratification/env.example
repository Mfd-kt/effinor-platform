## Public config (Vite)
## Create a `.env` or `.env.local` file (not committed) with these variables.

# Base site URL used for canonical/OG/schema (ex: https://landing.effinor.fr)
VITE_SITE_URL=

# Optional absolute logo URL used in Organization schema
VITE_LOGO_URL=

# Optional absolute OG image URL
VITE_OG_IMAGE_URL=

# Lead routing / tracking
VITE_MAKE_WEBHOOK_URL=
VITE_REDIRECT_URL=https://formulaire.groupe-effinor.fr/
VITE_WEB3FORMS_ACCESS_KEY=
VITE_BACKUP_EMAIL=leads.effinor@gmail.com

# Optional: Google Ads conversion "send_to" label (ex: AW-123456789/AbCdEfGhIjk)
VITE_GOOGLE_ADS_CONVERSION_SEND_TO=

